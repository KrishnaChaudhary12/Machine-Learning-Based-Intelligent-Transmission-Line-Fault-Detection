from sklearn.model_selection import train_test_split
non_feature_cols = ['fault_type', 'phases', 'location_km', 'r_fault', 'fault_start']
feature_cols = [c for c in df.columns if c not in non_feature_cols]
X =df[feature_cols]
y_type = df['fault_type']
X_train, X_test, y_train, y_test = train_test_split(
X, y_type, test_size=0.25, random_state=42, stratify=y_type
)
# Train size: (675, 36) Test size: (225, 36)


# Model 1 —Random Forest (Fault Type Classification)
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, classification_report
rf = RandomForestClassifier(n_estimators=300, random_state=42)
rf.fit(X_train, y_train)
y_pred = rf.predict(X_test)
print("Accuracy:", accuracy_score(y_test, y_pred))
print(classification_report(y_test, y_pred))

# Model 2 — Support Vector Machine (SVM)
from sklearn.svm import SVC
from sklearn.preprocessing import StandardScaler
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)
svm =SVC(kernel='rbf', C=10, gamma='scale', random_state=42)
svm.fit(X_train_scaled, y_train)
y_pred_svm = svm.predict(X_test_scaled)
print("SVM Accuracy:", accuracy_score(y_test, y_pred_svm)


#       Model 3 — XGBoost
from xgboost import XGBClassifier
from sklearn.preprocessing import LabelEncoder
le = LabelEncoder()
y_train_enc = le.fit_transform(y_train)
y_test_enc = le.transform(y_test)
xgb = XGBClassifier(n_estimators=300, random_state=42, eval_metric='mlogloss')
xgb.fit(X_train, y_train_enc)
y_pred_xgb = xgb.predict(X_test)
print("XGBoost Accuracy:", accuracy_score(y_test_enc, y_pred_xgb))

# Fault Location Estimation (Regression)
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_absolute_error
fault_mask = df['fault_type'] != 'NONE'
X_loc = df.loc[fault_mask, feature_cols]
y_loc = df.loc[fault_mask, 'location_km']
X_loc_train, X_loc_test, y_loc_train, y_loc_test = train_test_split(
X_loc, y_loc, test_size=0.25, random_state=42
)
rf_loc = RandomForestRegressor(n_estimators=300, random_state=42)
rf_loc.fit(X_loc_train, y_loc_train)
y_loc_pred = rf_loc.predict(X_loc_test)
mae=mean_absolute_error(y_loc_test, y_loc_pred)
print(f"Location MAE: {mae:.2f} km ({mae/150*100:.2f}% of line length)")
